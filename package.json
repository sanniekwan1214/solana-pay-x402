{
  "name": "solana-pay-x402",
  "version": "0.1.0",
  "description": "HTTP 402 payment middleware for Solana (Express + Next.js). Supports x402 v2 (programmatic, facilitator-managed) and Solana Pay (QR code, on-chain) from a single integration.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "require": "./dist/express/index.js",
      "import": "./dist/express/index.mjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs/index.d.ts",
      "require": "./dist/nextjs/index.js",
      "import": "./dist/nextjs/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build",
    "demo": "tsx demo/server.ts"
  },
  "keywords": [
    "solana",
    "solana-pay",
    "x402",
    "http-402",
    "payments",
    "micropayments",
    "crypto",
    "middleware",
    "express",
    "nextjs",
    "ai-agent"
  ],
  "author": "Sannie Kwan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanniekwan1214/solana-pay-x402.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "next": { "optional": true }
  },
  "dependencies": {
    "@solana/pay": "^0.2.5",
    "@solana/web3.js": "^1.95.0",
    "bignumber.js": "^9.3.1",
    "x402-solana": "^2.0.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "express": "^4.18.2",
    "tsup": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  }
}
